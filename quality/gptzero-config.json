{
  "version": "1.0",
  "api_endpoint": "https://api.gptzero.me/v2/predict/text",
  "auth_header": "x-api-key",
  "monthly_word_limit": 300000,
  "economy_mode": {
    "enabled": true,
    "default_sections": [5, 7, 13, 14],
    "description": "Check 4 key sections instead of full article"
  },
  "thresholds": {
    "human_only": 0.30,
    "mixed": 0.60,
    "ai_only": 0.60
  },
  "confidence_filter": "high",
  "max_chars_per_request": 150000,
  "request_timeout_ms": 10000,
  "severity": "P2",
  "notes": "Advisory only. High FPR (5-15%). Only high-confidence results are actionable. Key from Egor's account."
}
